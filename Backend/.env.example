# TMDB (فیلم) — https://www.themoviedb.org/settings/api
TMDB_API_KEY=

# Spotify (موزیک) — https://developer.spotify.com/dashboard
# Client Credentials Flow: فقط برای جست‌وجوی ترک/لینک/پیش‌نمایش، نیاز به لاگین کاربر ندارد
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Gemini (تحلیل احساسات هوشمند - اختیاری، در نبود آن از Rule-Based Fallback استفاده می‌شود)
GEMINI_API_KEY=

DEBUG=false
